{
	"name": "companion-module-clearcom-rest",
	"version": "0.3.4",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"postinstall": "husky",
		"format": "prettier -w .",
		"package": "yarn build && companion-module-build",
		"package:dev": "yarn build && companion-module-build --dev",
		"build": "rimraf dist && yarn build:main",
		"build:main": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"lint:raw": "eslint",
		"lint": "yarn lint:raw ."
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-your-module-name.git"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"dependencies": {
		"@companion-module/base": "~2.0.4",
		"fs": "^0.0.1-security",
		"openapi-types": "^12.1.3",
		"socket.io-client": "2"
	},
	"devDependencies": {
		"@companion-module/tools": "~3.0.0",
		"@types/node": "^25.6.0",
		"@types/socket.io-client": "^3.0.0",
		"eslint": "^10.2.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.0",
		"rimraf": "^6.1.0",
		"typescript": "~6.0.0",
		"typescript-eslint": "^8.59.0"
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"lint-staged": {
		"*.{css,json,md,scss}": [
			"prettier --write"
		],
		"*.{ts,tsx,js,jsx}": [
			"yarn lint:raw --fix"
		]
	},
	"packageManager": "yarn@4.12.0"
}
